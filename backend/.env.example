# Copy to .env and fill values
NEO4J_URI=neo4j+s://9d7baad4.databases.neo4j.io
NEO4J_USERNAME=9d7baad4
NEO4J_PASSWORD=H6yDmv3JyEi74ZBKl8m7hj6LMq7idNqjhNg6h16AQnc
NEO4J_DATABASE=9d7baad4
AURA_INSTANCEID=9d7baad4
AURA_INSTANCENAME=Free instance



# LLM: ollama (local) | gemini | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434ion
# Text model - resolved from available (e.g. llama3.1:8b-instruct -> llama3.1:8b)
OLLAMA_MODEL=llama3.1:8b
# Vision model - auto-detected if empty when llama3.2-vision is installed
OLLAMA_VISION_MODEL=

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Extraction: disable translation by default (avoids hangs). Set ENABLE_TRANSLATION=true for non-English PDFs
# ENABLE_TRANSLATION=false
# EXTRACT_CHARTS=true  # Chart extraction; text-heavy pages skip slow Vision

# Chunking: FAST_CHUNKING=false for full structural+semantic+size (3 sections → 3+ chunks)
FAST_CHUNKING=false

# Graph: hybrid NER+rules; parallel extract + staged Neo4j (defaults shown)
# GRAPH_EXTRACT_CONCURRENCY=5
# GRAPH_LLM_CACHE_MAX_ENTRIES=4096
# GRAPH_LLM_FALLBACK_THRESHOLD=0.38
# GRAPH_USE_SPACY_NER=false
# GRAPH_ENABLE_COMMUNITIES=true

# Content dedup: cosine sim >= this = same content (merge PDF text + OCR + Vision overlap)
# CONTENT_DEDUP_SIMILARITY_THRESHOLD=0.85

# Chunking: graph-aware coherence filter (drop chunks below this MiniLM score)
# CHUNK_COHERENCE_MIN=0.22

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3001

UPLOAD_DIR=./uploads
FAISS_INDEX_DIR=./faiss_index
LOG_LEVEL=INFO
